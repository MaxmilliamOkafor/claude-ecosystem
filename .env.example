# Anthropic API key — required for all three packages.
# Create one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default model used across Claude Code, Cowork, and the extension backend.
# See packages/shared/src/models.ts for the full supported list.
CLAUDE_MODEL=claude-opus-4-6

# Claude Cowork web server settings
COWORK_PORT=5174
COWORK_HOST=127.0.0.1
COWORK_SESSIONS_DIR=./.sessions

# Extension backend (the extension talks to Cowork's /api endpoints by default)
EXTENSION_API_BASE=http://127.0.0.1:5174

# Optional: enable verbose SDK logging
ANTHROPIC_LOG=info

{
  "name": "claude-cowork",
  "version": "1.0.0",
  "type": "module",
  "description": "Claude Cowork — chat + workspace + tasks + autonomous agent web app.",
  "scripts": {
    "dev": "concurrently -n srv,web -c cyan,magenta \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "pnpm build:web && pnpm build:server",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "test": "echo \"(no tests)\" && exit 0",
    "lint": "echo \"(no lint)\" && exit 0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@claude-eco/shared": "workspace:*",
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.0.1",
    "tsx": "^4.19.1",
    "vite": "^5.4.8"
  }
}

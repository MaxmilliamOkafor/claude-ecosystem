{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "module": "ESNext",
    "moduleResolution": "Node",
    "types": ["node"],
    "jsx": "preserve",
    "composite": false,
    "noEmit": false

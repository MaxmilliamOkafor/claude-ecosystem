{
  "name": "claude-ecosystem",
  "version": "1.0.0",
  "private": true,
  "description": "Complete Claude ecosystem: Claude Code CLI, Claude Cowork web app, and Claude browser extension.",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r --parallel run build",
    "dev": "pnpm -r --parallel run dev",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r exec rm -rf dist node_modules .turbo",
    "code": "pnpm --filter claude-code start",
    "cowork": "pnpm --filter claude-cowork dev",
    "ext:build": "pnpm --filter claude-extension build",
    "ext:watch": "pnpm --filter claude-extension dev"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "@types/node": "^22.7.4"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
